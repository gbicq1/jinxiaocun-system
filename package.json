{
  "name": "inventory-system",
  "version": "1.0.0",
  "description": "进销存管理系统",
  "main": "dist-electron/main.js",
  "author": "进销存开发团队",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "tsc -p electron/tsconfig.json && node -e \"require('fs').copyFileSync('electron/preload.js','dist-electron/preload.js')\" && electron dist-electron/main.js",
    "electron:dev": "concurrently -k \"vite\" \"tsc -p electron/tsconfig.json --watch\" \"node -e \\\"require('fs').copyFileSync('electron/preload.js','dist-electron/preload.js')\\\" && electron dist-electron/main.js\"",
    "electron:build": "vite build && tsc -p electron/tsconfig.json && node -e \"require('fs').copyFileSync('electron/preload.js','dist-electron/preload.js')\" && electron-builder --win",
    "electron:rebuild": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "better-sqlite3": "^8.7.0",
    "dayjs": "^1.11.10",
    "element-plus": "^2.4.4",
    "pinia": "^2.1.7",
    "sql.js": "^1.14.1",
    "vue": "^3.4.0",
    "vue-router": "^4.2.5",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^16.18.0",
    "@vitejs/plugin-vue": "^4.5.0",
    "concurrently": "^8.2.0",
    "electron": "^21.4.4",
    "electron-builder": "^24.13.3",
    "electron-rebuild": "^3.2.9",
    "node-gyp": "^10.1.0",
    "sass-embedded": "^1.69.0",
    "tsc-watch": "^6.0.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.0",
    "vue-tsc": "^1.8.27"
  }
}
