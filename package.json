{
  "name": "inventory-system",
  "version": "1.0.0",
  "description": "进销存管理系统",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "tsc -p electron/tsconfig.json && electron electron/main.js",
    "electron:dev": "concurrently -k \"vite\" \"tsc -p electron/tsconfig.json --watch\" \"electron electron/main.js\"",
    "electron:build": "vite build && tsc -p electron/tsconfig.json && electron-builder"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "better-sqlite3": "^12.8.0",
    "dayjs": "^1.11.10",
    "element-plus": "^2.4.4",
    "pinia": "^2.1.7",
    "vue": "^3.4.0",
    "vue-router": "^4.2.5",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^20.10.5",
    "@vitejs/plugin-vue": "^4.5.0",
    "concurrently": "^9.2.1",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9",
    "sass-embedded": "^1.99.0",
    "tsc-watch": "^7.2.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.0",
    "vue-tsc": "^1.8.27"
  }
}
