{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "../dist-electron",
    "rootDir": "./",
    "resolveJsonModule": true,
    "types": ["node"],
    "strictNullChecks": false
  },
  "include": ["./**/*"],
  "exclude": ["node_modules"]
}
